{
  "name": "outlabs-auth-ui",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "deploy:cloudflare": "bun run build && bash scripts/deploy-with-env.sh",
    "typecheck": "tsc -b",
    "lint": "eslint .",
    "lint:architecture-fixtures": "bash scripts/check-architecture-fixtures.sh",
    "preview": "vite preview",
    "test:e2e:a11y": "playwright test e2e/a11y/a11y-smoke.spec.ts",
    "test:e2e:account": "playwright test e2e/account/account-workspace.spec.ts",
    "test:e2e:app": "playwright test e2e/app",
    "test:e2e:api-keys": "playwright test e2e/api-keys/api-keys-workspace.spec.ts e2e/api-keys/api-keys-persona-access.spec.ts",
    "test:e2e:auth": "playwright test e2e/auth/auth-flow.spec.ts e2e/auth/oauth-flow.spec.ts",
    "test:e2e:oauth": "playwright test e2e/auth/oauth-flow.spec.ts",
    "test:e2e": "playwright test",
    "test:e2e:fixtures": "bash scripts/run-e2e-fixtures.sh",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:entities": "playwright test e2e/entities/entities-workspace.spec.ts",
    "test:e2e:no-reset": "E2E_RESET_BACKEND=0 playwright test",
    "test:e2e:permissions": "playwright test e2e/permissions/permissions-workspace.spec.ts",
    "test:e2e:reset-backend": "bun run e2e/support/reset-backend.ts",
    "test:e2e:roles": "playwright test e2e/roles/roles-workspace.spec.ts",
    "test:e2e:settings": "playwright test e2e/settings/settings-workspace.spec.ts",
    "test:e2e:simple": "E2E_FIXTURE=simple E2E_REUSE_EXISTING_SERVER=0 E2E_API_BASE_URL=http://localhost:8003 E2E_BACKEND_RESET_SCRIPT=/Users/macbookm3/Documents/projects/outlabsAuth/examples/simple_rbac/reset_test_env.py E2E_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/blog_simple_rbac E2E_PERSONAS=admin E2E_ADMIN_EMAIL=admin@test.com E2E_ADMIN_PASSWORD=Test123!! playwright test",
    "test:e2e:simple:api-keys": "E2E_FIXTURE=simple E2E_REUSE_EXISTING_SERVER=0 E2E_API_BASE_URL=http://localhost:8003 E2E_BACKEND_RESET_SCRIPT=/Users/macbookm3/Documents/projects/outlabsAuth/examples/simple_rbac/reset_test_env.py E2E_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/blog_simple_rbac E2E_PERSONAS=admin E2E_ADMIN_EMAIL=admin@test.com E2E_ADMIN_PASSWORD=Test123!! playwright test e2e/api-keys/api-keys-simple-rbac.spec.ts",
    "test:e2e:users": "playwright test e2e/users/users-workspace.spec.ts",
    "test:e2e:pagination": "playwright test e2e/app/workspace-pagination.spec.ts",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@fontsource-variable/geist": "^5.2.8",
    "@hookform/resolvers": "^5.2.2",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-query-devtools": "^5.91.3",
    "@tanstack/react-router": "^1.167.3",
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.577.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.71.2",
    "shadcn": "^4.0.8",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/eslint-plugin-query": "^5.101.3",
    "@tanstack/router-plugin": "^1.166.12",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
